# Nisria Grant Finder env vars
#
# Copy to .env locally, or paste into Railway's Variables tab in production.
# Production secrets live in Railway, not in this repo.

# Claude API key for Stage 2 LLM re-rank + Application AI helper.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# SAM.gov key (optional; only if SAM.gov source is enabled in config.yaml).
# Free at https://sam.gov/data-services
SAM_GOV_API_KEY=

# First-run admin bootstrap. Only used on the very first server start when
# the users table is empty. After bootstrap, the user is stored hashed in
# the database and these env vars are no longer the source of truth.
NUR_EMAIL=nur@nisria.co
NUR_PASSWORD=change-me-on-first-deploy

# Session cookie signing key. Must be a random string of at least 32 chars.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Optional: override config file path
# CONFIG_PATH=config/config.yaml
